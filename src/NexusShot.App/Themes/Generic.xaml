<!--
    Default styles for the custom controls in NexusShot.App.Controls.

    A control that sets DefaultStyleKey resolves its template from Themes/Generic.xaml by
    convention, and only from there: an implicit style in App.Resources is not consulted. The keyed
    styles live in Controls.xaml; these implicit styles simply point each control at its own.
-->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:NexusShot.App.Controls">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="ms-appx:///Themes/Tokens.xaml" />
        <ResourceDictionary Source="ms-appx:///Themes/Controls.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <Style BasedOn="{StaticResource ToolTileStyle}" TargetType="controls:ToolTile" />
    <Style BasedOn="{StaticResource ColorSwatchStyle}" TargetType="controls:ColorSwatch" />
    <Style BasedOn="{StaticResource HexColorPickerStyle}" TargetType="controls:HexColorPicker" />

</ResourceDictionary>
