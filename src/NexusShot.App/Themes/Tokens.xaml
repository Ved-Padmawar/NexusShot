<!--
    Design tokens for the NexusShot shell.

    Every brush is declared once per theme inside ThemeDictionaries. Consumers must reference these
    with {ThemeResource}, never {StaticResource}: StaticResource snapshots the brush at load time,
    so a control resolved under one theme keeps that brush forever and the window half-switches.
    ThemeResource re-resolves whenever RequestedTheme changes on an ancestor.

    The two themes are not inverses of each other. Dark leans on lightness for elevation (a raised
    surface is lighter than its base); light leans on it in the opposite direction only for the
    sunken canvas well, because a screenshot needs to read as inset from the chrome in both themes.
-->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.ThemeDictionaries>

        <!--  ===================  DARK  ===================  -->
        <ResourceDictionary x:Key="Dark">
            <!--  Surfaces. Elevation is lightness, not shadow.  -->
            <SolidColorBrush x:Key="SurfaceSunken" Color="#0E0E10" />
            <SolidColorBrush x:Key="SurfaceBase" Color="#141417" />
            <SolidColorBrush x:Key="SurfaceRaised" Color="#17171A" />
            <SolidColorBrush x:Key="SurfaceOverlay" Color="#1E1E22" />

            <!--  Hairlines: white at low alpha, so they hold over any surface.  -->
            <SolidColorBrush x:Key="StrokeSubtle" Color="#14FFFFFF" />
            <SolidColorBrush x:Key="StrokeDefault" Color="#1FFFFFFF" />
            <SolidColorBrush x:Key="StrokeStrong" Color="#33FFFFFF" />

            <!--  Interaction fills.  -->
            <SolidColorBrush x:Key="FillHover" Color="#12FFFFFF" />
            <SolidColorBrush x:Key="FillPressed" Color="#0AFFFFFF" />
            <SolidColorBrush x:Key="FillSelected" Color="#1FFFFFFF" />

            <SolidColorBrush x:Key="TextPrimary" Color="#F2F2F4" />
            <SolidColorBrush x:Key="TextSecondary" Color="#9A9AA2" />
            <SolidColorBrush x:Key="TextTertiary" Color="#6A6A72" />
            <SolidColorBrush x:Key="TextOnAccent" Color="#FFFFFF" />

            <SolidColorBrush x:Key="Accent" Color="#0A84FF" />
            <SolidColorBrush x:Key="AccentHover" Color="#3D9BFF" />
            <SolidColorBrush x:Key="AccentPressed" Color="#0069D9" />
            <SolidColorBrush x:Key="Danger" Color="#FF453A" />

            <!--  Scrim behind the floating card's hover actions.  -->
            <SolidColorBrush x:Key="HoverScrim" Color="#B3000000" />

            <!--
                Scrims drawn *over* a thumbnail. Deliberately not the FillHover/FillSelected chrome
                fills: those are ~7% white, which shifts a bright screenshot by 1/255 — invisible.
                A scrim over captured pixels must darken, and must do so in both themes.
            -->
            <!--  Selection is an elevated neutral pill (Option 1), not a blue tint: an opaque raised
                  surface a step lighter than the sidebar, reading as lifted rather than coloured, and
                  framing the thumbnail since it sits *behind* the row. A hairline stroke frames the
                  pill; hover/pressed stay near-neutral white with no stroke.  -->
            <SolidColorBrush x:Key="RowHoverFill" Color="#FFFFFF" Opacity="0.06" />
            <SolidColorBrush x:Key="RowPressedFill" Color="#FFFFFF" Opacity="0.03" />
            <SolidColorBrush x:Key="RowSelectFill" Color="#1E1E22" />
            <SolidColorBrush x:Key="RowSelectFillHover" Color="#1E1E22" />
            <SolidColorBrush x:Key="RowSelectStroke" Color="#FFFFFF" Opacity="0.08" />
        </ResourceDictionary>

        <!--  ===================  LIGHT  ===================  -->
        <ResourceDictionary x:Key="Light">
            <!--  The canvas well stays the darkest surface so the capture reads as inset.  -->
            <SolidColorBrush x:Key="SurfaceSunken" Color="#E4E4E7" />
            <SolidColorBrush x:Key="SurfaceBase" Color="#F7F7F9" />
            <SolidColorBrush x:Key="SurfaceRaised" Color="#FFFFFF" />
            <SolidColorBrush x:Key="SurfaceOverlay" Color="#FFFFFF" />

            <!--  Black at low alpha: the mirror of the dark hairlines, not a lightened copy.  -->
            <SolidColorBrush x:Key="StrokeSubtle" Color="#0F000000" />
            <SolidColorBrush x:Key="StrokeDefault" Color="#1A000000" />
            <SolidColorBrush x:Key="StrokeStrong" Color="#33000000" />

            <SolidColorBrush x:Key="FillHover" Color="#0D000000" />
            <SolidColorBrush x:Key="FillPressed" Color="#1A000000" />
            <SolidColorBrush x:Key="FillSelected" Color="#14000000" />

            <SolidColorBrush x:Key="TextPrimary" Color="#1C1C1E" />
            <SolidColorBrush x:Key="TextSecondary" Color="#4A4A52" />
            <!--  #8E8E96 was only 2.56:1 on SurfaceSunken, under the 3:1 floor for UI text.  -->
            <SolidColorBrush x:Key="TextTertiary" Color="#5E5E66" />
            <SolidColorBrush x:Key="TextOnAccent" Color="#FFFFFF" />

            <!--  Slightly darker accent: #0A84FF on white fails contrast for small text.  -->
            <SolidColorBrush x:Key="Accent" Color="#0069D9" />
            <SolidColorBrush x:Key="AccentHover" Color="#0A84FF" />
            <SolidColorBrush x:Key="AccentPressed" Color="#0055B0" />
            <SolidColorBrush x:Key="Danger" Color="#D70015" />

            <!--  The card scrim stays dark in both themes: it sits over captured pixels.  -->
            <SolidColorBrush x:Key="HoverScrim" Color="#B3000000" />

            <!--
                Row scrims *lighten* here, where the dark theme's darken. The scrim tints the row's
                text as well as its thumbnail, and light-theme text is dark: a darkening scrim moves
                the background toward the text and collapses contrast — the subtitle fell to 1.5:1,
                and no text colour fixes it, because darkening always closes the gap. Lightening
                pushes the surface away from the text (contrast *rises* on hover) and still tints a
                thumbnail, since the row's surface is grey rather than white.
            -->
            <!--  Selection is a neutral elevated pill (Option 1), not a tint: an opaque raised white
                  that lifts off the cool grey sidebar by elevation rather than a hue, and frames the
                  thumbnail since it sits *behind* the row. A neutral hairline stroke frames the pill;
                  hover/pressed stay near-neutral grey with no stroke.  -->
            <SolidColorBrush x:Key="RowHoverFill" Color="#000000" Opacity="0.055" />
            <SolidColorBrush x:Key="RowPressedFill" Color="#000000" Opacity="0.09" />
            <SolidColorBrush x:Key="RowSelectFill" Color="#FFFFFF" />
            <SolidColorBrush x:Key="RowSelectFillHover" Color="#FFFFFF" />
            <SolidColorBrush x:Key="RowSelectStroke" Color="#000000" Opacity="0.14" />
        </ResourceDictionary>

    </ResourceDictionary.ThemeDictionaries>

    <!--  Theme-invariant tokens. Geometry and type do not change with the palette.  -->
    <CornerRadius x:Key="RadiusControl">6</CornerRadius>
    <CornerRadius x:Key="RadiusContainer">10</CornerRadius>

    <x:Double x:Key="FontSizeCaption">11</x:Double>
    <x:Double x:Key="FontSizeBody">13</x:Double>
    <x:Double x:Key="FontSizeSubtitle">15</x:Double>
    <x:Double x:Key="FontSizeTitle">20</x:Double>

</ResourceDictionary>
