<Window
    x:Class="NexusShot.App.Views.EditorWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:NexusShot.App.Controls"
    Title="NexusShot — Editor">

    <Grid x:Name="Root" Background="{ThemeResource SurfaceBase}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Custom titlebar strip, matching the main window's extended-content chrome. It is the
              window's drag region; the file name doubles as the window title.  -->
        <Border
            x:Name="TitleBarArea"
            Height="36"
            Background="{ThemeResource SurfaceRaised}">
            <TextBlock
                x:Name="TitleBarText"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="{StaticResource FontSizeCaption}"
                Foreground="{ThemeResource TextTertiary}" />
        </Border>

        <!--
            Toolbar. Tools are grouped by what they do — shapes, freehand, redaction, framing —
            with hairline separators, so thirteen tiles read as four short groups rather than one
            undifferentiated row.
        -->
        <Border
            Grid.Row="1"
            Padding="12,8"
            Background="{ThemeResource SurfaceRaised}"
            BorderBrush="{ThemeResource StrokeSubtle}"
            BorderThickness="0,0,0,1">
            <Grid ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel
                    x:Name="ToolPanel"
                    Orientation="Horizontal"
                    Spacing="1">
                    <controls:ToolTile Tool="Select" ToolTipService.ToolTip="Select  (V)">
                        <FontIcon FontSize="15" Glyph="&#xE8B0;" />
                    </controls:ToolTile>

                    <Rectangle Style="{StaticResource ToolSeparatorStyle}" />

                    <controls:ToolTile Tool="Rectangle" ToolTipService.ToolTip="Rectangle  (R)">
                        <FontIcon FontSize="15" Glyph="&#xE739;" />
                    </controls:ToolTile>
                    <controls:ToolTile Tool="Ellipse" ToolTipService.ToolTip="Ellipse  (E)">
                        <FontIcon FontSize="15" Glyph="&#xEA3A;" />
                    </controls:ToolTile>
                    <controls:ToolTile Tool="Arrow" ToolTipService.ToolTip="Arrow  (A)">
                        <FontIcon FontSize="15" Glyph="&#xE8AD;" />
                    </controls:ToolTile>
                    <controls:ToolTile Tool="Line" ToolTipService.ToolTip="Line  (L)">
                        <FontIcon FontSize="15" Glyph="&#xE738;" />
                    </controls:ToolTile>

                    <Rectangle Style="{StaticResource ToolSeparatorStyle}" />

                    <controls:ToolTile Tool="Pen" ToolTipService.ToolTip="Pen  (D)">
                        <FontIcon FontSize="15" Glyph="&#xE70F;" />
                    </controls:ToolTile>
                    <controls:ToolTile Tool="Brush" ToolTipService.ToolTip="Brush  (M)">
                        <FontIcon FontSize="15" Glyph="&#xE790;" />
                    </controls:ToolTile>
                    <controls:ToolTile Tool="Eraser" ToolTipService.ToolTip="Erase pen and brush  (X)">
                        <FontIcon FontSize="15" Glyph="&#xE75C;" />
                    </controls:ToolTile>
                    <controls:ToolTile Tool="Text" ToolTipService.ToolTip="Text  (T)">
                        <FontIcon FontSize="15" Glyph="&#xE8D2;" />
                    </controls:ToolTile>
                    <controls:ToolTile Tool="Counter" ToolTipService.ToolTip="Counter  (N)">
                        <FontIcon FontSize="15" Glyph="&#xE8EF;" />
                    </controls:ToolTile>

                    <Rectangle Style="{StaticResource ToolSeparatorStyle}" />

                    <controls:ToolTile Tool="Highlight" ToolTipService.ToolTip="Highlight  (H)">
                        <FontIcon FontSize="15" Glyph="&#xE7E6;" />
                    </controls:ToolTile>
                    <controls:ToolTile Tool="Blur" ToolTipService.ToolTip="Blur  (B)">
                        <FontIcon FontSize="15" Glyph="&#xE890;" />
                    </controls:ToolTile>
                    <controls:ToolTile Tool="Pixelate" ToolTipService.ToolTip="Pixelate  (P)">
                        <FontIcon FontSize="15" Glyph="&#xE80A;" />
                    </controls:ToolTile>
                    <controls:ToolTile Tool="Spotlight" ToolTipService.ToolTip="Spotlight  (S)">
                        <FontIcon FontSize="15" Glyph="&#xE706;" />
                    </controls:ToolTile>

                    <Rectangle Style="{StaticResource ToolSeparatorStyle}" />

                    <controls:ToolTile Tool="Crop" ToolTipService.ToolTip="Crop  (C)">
                        <FontIcon FontSize="15" Glyph="&#xE7A8;" />
                    </controls:ToolTile>
                </StackPanel>

                <!--  Colour + thickness  -->
                <StackPanel
                    Grid.Column="1"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="14">
                    <StackPanel
                        x:Name="ColorPanel"
                        VerticalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="2" />
                    <!--  The chip is the live colour and the hex is its readout, so the button
                          states the current colour instead of merely advertising that colours exist.  -->
                    <Button
                        Style="{StaticResource ChipButtonStyle}"
                        ToolTipService.ToolTip="Choose custom color">
                        <StackPanel
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="7">
                            <Border
                                Width="16"
                                Height="16"
                                CornerRadius="4"
                                BorderBrush="{ThemeResource StrokeStrong}"
                                BorderThickness="1">
                                <Rectangle
                                    x:Name="CurrentColorPreview"
                                    Fill="#FF3B30"
                                    RadiusX="3"
                                    RadiusY="3" />
                            </Border>
                            <TextBlock
                                x:Name="CurrentColorHex"
                                VerticalAlignment="Center"
                                FontFamily="Consolas, Cascadia Mono, monospace"
                                FontSize="{StaticResource FontSizeCaption}"
                                Foreground="{ThemeResource TextSecondary}"
                                Text="#FF3B30" />
                            <FontIcon
                                VerticalAlignment="Center"
                                FontSize="8"
                                Foreground="{ThemeResource TextTertiary}"
                                Glyph="&#xE70D;" />
                        </StackPanel>
                        <Button.Flyout>
                            <Flyout Opening="ColorFlyout_Opening">
                                <Flyout.FlyoutPresenterStyle>
                                    <Style TargetType="FlyoutPresenter">
                                        <Setter Property="Padding" Value="12" />
                                        <Setter Property="Background" Value="{ThemeResource SurfaceOverlay}" />
                                        <Setter Property="BorderBrush" Value="{ThemeResource StrokeDefault}" />
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Setter Property="CornerRadius" Value="{StaticResource RadiusContainer}" />
                                    </Style>
                                </Flyout.FlyoutPresenterStyle>
                                <controls:HexColorPicker
                                    x:Name="CustomColorPicker"
                                    ColorPicked="CustomColorPicker_ColorPicked" />
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                    <Rectangle Style="{StaticResource ToolSeparatorStyle}" />
                    <Slider
                        x:Name="ThicknessSlider"
                        Width="96"
                        VerticalAlignment="Center"
                        Maximum="100"
                        Minimum="1"
                        PointerCaptureLost="Thickness_DragEnded"
                        ToolTipService.ToolTip="Stroke thickness"
                        Value="4"
                        ValueChanged="Thickness_Changed" />

                    <!--  Text formatting; shown while the text tool is active or a text
                          annotation is selected or being edited.  -->
                    <StackPanel
                        x:Name="TextFormatPanel"
                        Orientation="Horizontal"
                        Spacing="6"
                        Visibility="Collapsed">
                        <Rectangle Style="{StaticResource ToolSeparatorStyle}" />
                        <ComboBox
                            x:Name="FontSizeBox"
                            Width="70"
                            VerticalAlignment="Center"
                            SelectionChanged="FontSize_Changed"
                            ToolTipService.ToolTip="Font size" />
                        <ToggleButton
                            x:Name="BoldToggle"
                            Width="30"
                            Height="30"
                            Padding="0"
                            VerticalAlignment="Center"
                            Click="TextFormat_Changed"
                            ToolTipService.ToolTip="Bold">
                            <FontIcon FontSize="13" Glyph="&#xE8DD;" />
                        </ToggleButton>
                        <ToggleButton
                            x:Name="ItalicToggle"
                            Width="30"
                            Height="30"
                            Padding="0"
                            VerticalAlignment="Center"
                            Click="TextFormat_Changed"
                            ToolTipService.ToolTip="Italic">
                            <FontIcon FontSize="13" Glyph="&#xE8DB;" />
                        </ToggleButton>
                        <ToggleButton
                            x:Name="UnderlineToggle"
                            Width="30"
                            Height="30"
                            Padding="0"
                            VerticalAlignment="Center"
                            Click="TextFormat_Changed"
                            ToolTipService.ToolTip="Underline">
                            <FontIcon FontSize="13" Glyph="&#xE8DC;" />
                        </ToggleButton>
                    </StackPanel>
                </StackPanel>

                <StackPanel
                    Grid.Column="2"
                    Orientation="Horizontal"
                    Spacing="1">
                    <Button
                        x:Name="UndoButton"
                        Click="Undo_Click"
                        Style="{StaticResource IconButtonStyle}"
                        ToolTipService.ToolTip="Undo  (Ctrl+Z)">
                        <FontIcon FontSize="14" Glyph="&#xE7A7;" />
                    </Button>
                    <Button
                        x:Name="RedoButton"
                        Click="Redo_Click"
                        Style="{StaticResource IconButtonStyle}"
                        ToolTipService.ToolTip="Redo  (Ctrl+Y)">
                        <FontIcon FontSize="14" Glyph="&#xE7A6;" />
                    </Button>
                    <Button
                        Click="Delete_Click"
                        Style="{StaticResource IconButtonStyle}"
                        ToolTipService.ToolTip="Delete selected  (Del)">
                        <FontIcon FontSize="14" Glyph="&#xE74D;" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!--  Canvas well. Sunken, so the capture reads as inset from the chrome in both themes.  -->
        <ScrollViewer
            x:Name="CanvasScroller"
            Grid.Row="2"
            Padding="28"
            Background="{ThemeResource SurfaceSunken}"
            HorizontalScrollBarVisibility="Auto"
            VerticalScrollBarVisibility="Auto"
            ZoomMode="Disabled">
            <!--  The frame is a non-clipping Grid rather than a Border containing ImageHost.
                  Selection adorners are centered on image-edge geometry and may extend half a
                  grip outside it, as in graphics-scene editors. The decorative border remains a
                  separate child and does not clip those adorners.  -->
            <Grid
                x:Name="CanvasFrame"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
                <Border
                    BorderBrush="{ThemeResource StrokeDefault}"
                    BorderThickness="1"
                    IsHitTestVisible="False" />
                <controls:CursorInteractionGrid
                    x:Name="ImageHost"
                    Background="Transparent"
                    DoubleTapped="Canvas_DoubleTapped"
                    PointerMoved="Canvas_PointerMoved"
                    PointerExited="Canvas_PointerExited"
                    PointerPressed="Canvas_PointerPressed"
                    PointerReleased="Canvas_PointerReleased">
                    <Image x:Name="BaseImage" Stretch="Fill" />
                    <Canvas x:Name="AnnotationCanvas" IsHitTestVisible="False" />
                    <!--  Image-space brush outline. Unlike a native HCURSOR, this is not silently
                          rescaled by Windows, so its diameter remains the exact paint footprint.  -->
                    <Canvas IsHitTestVisible="False">
                        <Ellipse
                            x:Name="BrushCursorOuter"
                            Stroke="Black"
                            Visibility="Collapsed" />
                        <Ellipse
                            x:Name="BrushCursorInner"
                            Stroke="White"
                            Visibility="Collapsed" />
                    </Canvas>
                    <!--  Hosts the inline TextBox while a text annotation is being typed.  -->
                    <Canvas x:Name="TextEditCanvas" />
                </controls:CursorInteractionGrid>
            </Grid>
        </ScrollViewer>

        <!--  Bottom bar  -->
        <Border
            Grid.Row="3"
            Padding="14,10"
            Background="{ThemeResource SurfaceRaised}"
            BorderBrush="{ThemeResource StrokeSubtle}"
            BorderThickness="0,1,0,0">
            <Grid>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock
                        x:Name="StatusText"
                        VerticalAlignment="Center"
                        FontSize="{StaticResource FontSizeCaption}"
                        Foreground="{ThemeResource TextTertiary}" />
                    <Button
                        x:Name="FitZoomButton"
                        Click="FitZoom_Click"
                        Style="{StaticResource ShellButtonStyle}"
                        ToolTipService.ToolTip="Fit image to window (Ctrl+0)"
                        Content="Fit" />
                    <Button
                        x:Name="ActualPixelsButton"
                        Click="ActualPixels_Click"
                        Style="{StaticResource ShellButtonStyle}"
                        ToolTipService.ToolTip="One image pixel per screen pixel (Ctrl+1)"
                        Content="100%" />
                </StackPanel>
                <StackPanel
                    HorizontalAlignment="Right"
                    Orientation="Horizontal"
                    Spacing="8">
                    <Button
                        Click="Copy_Click"
                        Style="{StaticResource ShellButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon FontSize="14" Glyph="&#xE8C8;" />
                            <TextBlock Text="Copy" />
                        </StackPanel>
                    </Button>
                    <Button
                        Click="SaveAs_Click"
                        Style="{StaticResource ShellButtonStyle}"
                        ToolTipService.ToolTip="Save to a new file  (Ctrl+Shift+S)">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon FontSize="14" Glyph="&#xE74E;" />
                            <TextBlock Text="Save as…" />
                        </StackPanel>
                    </Button>
                    <Button
                        Click="Save_Click"
                        Style="{StaticResource ShellAccentButtonStyle}"
                        ToolTipService.ToolTip="Save over this file  (Ctrl+S)">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon FontSize="14" Glyph="&#xE74E;" />
                            <TextBlock Text="Save" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border
            x:Name="SaveToast"
            Grid.Row="2"
            Margin="0,18,0,0"
            Padding="14,9"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Background="{ThemeResource SurfaceRaised}"
            BorderBrush="{ThemeResource StrokeDefault}"
            BorderThickness="1"
            CornerRadius="8"
            IsHitTestVisible="False"
            Visibility="Collapsed">
            <TextBlock
                x:Name="SaveToastText"
                Foreground="{ThemeResource TextPrimary}"
                Text="Saved" />
        </Border>
    </Grid>
</Window>
