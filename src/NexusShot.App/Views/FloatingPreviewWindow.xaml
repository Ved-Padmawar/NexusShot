<Window
    x:Class="NexusShot.App.Views.FloatingPreviewWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="NexusShot Preview">

    <!--
        No padding and no drop shadow: a WinUI 3 window has no transparent backdrop, so any area the
        card does not cover renders as opaque black. The card must fill the window edge to edge.

        The card's own colours are fixed rather than themed. It floats over captured pixels, not over
        app chrome, so a light-theme card would wash out against a bright screenshot.
    -->
    <!--  Dark, not themed: any sliver the image does not cover (decode latency, rounding at the
          DWM corners) must read as shadow, never as a white edge.  -->
    <Grid x:Name="Root" Background="#141416">
        <Grid.Resources>
            <Style x:Key="OverlayActionStyle" TargetType="Button">
                <Setter Property="Width" Value="26" />
                <Setter Property="Height" Value="26" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="CornerRadius" Value="13" />
                <Setter Property="Background" Value="#E6202024" />
                <Setter Property="BorderBrush" Value="#26FFFFFF" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Foreground" Value="White" />
            </Style>
        </Grid.Resources>

        <!--  The thumbnail is the card, filling the window edge to edge. The -1 margin overscans
              the frame so DIP/pixel rounding can never expose the backdrop at an edge.  -->
        <Border x:Name="Card" Margin="-1">
            <Grid>
                <Image x:Name="PreviewImage" Stretch="UniformToFill" />

                <!--  Hover layer: dim + actions.  -->
                <Grid
                    x:Name="HoverLayer"
                    IsHitTestVisible="False"
                    Opacity="0">
                    <Rectangle Fill="#B3000000" />
                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="5">
                        <Button
                            Click="Copy_Click"
                            Style="{StaticResource OverlayActionStyle}"
                            ToolTipService.ToolTip="Copy  (Ctrl+C)">
                            <FontIcon FontSize="12" Glyph="&#xE8C8;" />
                        </Button>
                        <Button
                            Click="Save_Click"
                            Style="{StaticResource OverlayActionStyle}"
                            ToolTipService.ToolTip="Save as…  (Ctrl+S)">
                            <FontIcon FontSize="12" Glyph="&#xE74E;" />
                        </Button>
                        <Button
                            Click="Edit_Click"
                            Style="{StaticResource OverlayActionStyle}"
                            ToolTipService.ToolTip="Edit  (Ctrl+E)">
                            <FontIcon FontSize="12" Glyph="&#xE70F;" />
                        </Button>
                        <Button
                            x:Name="PinButton"
                            Click="Pin_Click"
                            Style="{StaticResource OverlayActionStyle}"
                            ToolTipService.ToolTip="Pin  (Ctrl+P)">
                            <FontIcon FontSize="12" Glyph="&#xE718;" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!--  Close affordance, inset from the card's top-right corner.  -->
        <Button
            x:Name="CloseButton"
            Width="18"
            Height="18"
            Margin="0,4,4,0"
            Padding="0"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Background="#F2323236"
            BorderBrush="#59FFFFFF"
            BorderThickness="1"
            Click="Dismiss_Click"
            CornerRadius="10"
            Foreground="White"
            Opacity="0"
            ToolTipService.ToolTip="Dismiss  (Esc)">
            <FontIcon FontSize="8" Glyph="&#xE711;" />
        </Button>
    </Grid>
</Window>
