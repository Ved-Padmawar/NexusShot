<Window
    x:Class="NexusShot.App.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:NexusShot.App.Controls"
    xmlns:vm="using:NexusShot.App.ViewModels"
    Title="NexusShot">

    <!--
        Sidebar browses; the detail pane previews and acts. Annotating opens the editor as its own
        window rather than docking it here: a docked editor would permanently surrender the sidebar's
        width from the image, on every edit, to a list the user is no longer looking at.
    -->
    <Grid
        x:Name="Root"
        Background="{ThemeResource SurfaceBase}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="248" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Button
            x:Name="FocusSink"
            Width="1"
            Height="1"
            IsHitTestVisible="False"
            IsTabStop="False"
            Opacity="0" />

        <!--  ============================  SIDEBAR  ============================  -->
        <Grid Background="{ThemeResource SurfaceSunken}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  Brand  -->
            <StackPanel
                Padding="18,20,18,16"
                Orientation="Horizontal"
                Spacing="10">
                <controls:BrandMark Width="22" Height="22" />
                <TextBlock
                    x:Name="BrandTitle"
                    VerticalAlignment="Center"
                    FontSize="{StaticResource FontSizeSubtitle}"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource TextPrimary}"
                    Text="NexusShot" />
                <Border
                    Height="18"
                    MinWidth="18"
                    Padding="7,0"
                    VerticalAlignment="Center"
                    Background="{ThemeResource SurfaceOverlay}"
                    CornerRadius="9">
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="11"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource TextTertiary}"
                        Text="{x:Bind AppVersionLabel}"
                        TextLineBounds="Tight" />
                </Border>
            </StackPanel>

            <!--  Capture actions  -->
            <StackPanel
                Grid.Row="1"
                Padding="10,0,10,14"
                Spacing="1">
                <Button
                    Click="Region_Click"
                    Style="{StaticResource CaptureActionStyle}"
                    ToolTipService.ToolTip="Capture a region of the screen">
                    <Grid ColumnSpacing="11">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <FontIcon
                            FontSize="15"
                            Foreground="{ThemeResource Accent}"
                            Glyph="&#xE7A8;" />
                        <TextBlock
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            FontSize="{StaticResource FontSizeBody}"
                            Foreground="{ThemeResource TextPrimary}"
                            Text="Region" />
                        <TextBlock
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            FontSize="{StaticResource FontSizeCaption}"
                            Foreground="{ThemeResource TextTertiary}"
                            Text="⌃⇧S" />
                    </Grid>
                </Button>

                <Button
                    Click="FullScreen_Click"
                    Style="{StaticResource CaptureActionStyle}"
                    ToolTipService.ToolTip="Capture every monitor">
                    <Grid ColumnSpacing="11">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <FontIcon
                            FontSize="15"
                            Foreground="{ThemeResource Accent}"
                            Glyph="&#xE7F4;" />
                        <TextBlock
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            FontSize="{StaticResource FontSizeBody}"
                            Foreground="{ThemeResource TextPrimary}"
                            Text="Full screen" />
                        <TextBlock
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            FontSize="{StaticResource FontSizeCaption}"
                            Foreground="{ThemeResource TextTertiary}"
                            Text="⌃⇧F" />
                    </Grid>
                </Button>

                <Button
                    Click="ActiveWindow_Click"
                    Style="{StaticResource CaptureActionStyle}"
                    ToolTipService.ToolTip="Capture the foreground window">
                    <Grid ColumnSpacing="11">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <FontIcon
                            FontSize="15"
                            Foreground="{ThemeResource Accent}"
                            Glyph="&#xE737;" />
                        <TextBlock
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            FontSize="{StaticResource FontSizeBody}"
                            Foreground="{ThemeResource TextPrimary}"
                            Text="Active window" />
                        <TextBlock
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            FontSize="{StaticResource FontSizeCaption}"
                            Foreground="{ThemeResource TextTertiary}"
                            Text="⌃⇧W" />
                    </Grid>
                </Button>
            </StackPanel>

            <!--  Section header  -->
            <Grid
                Grid.Row="2"
                Padding="20,4,14,8"
                BorderBrush="{ThemeResource StrokeSubtle}"
                BorderThickness="0,1,0,0">
                <TextBlock
                    Margin="0,10,0,0"
                    FontSize="{StaticResource FontSizeCaption}"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource TextTertiary}"
                    Text="RECENT" />
            </Grid>

            <!--  Capture list  -->
            <ListView
                x:Name="HistoryList"
                Grid.Row="3"
                Padding="10,0,10,10"
                IsItemClickEnabled="False"
                ItemContainerStyle="{StaticResource CaptureRowStyle}"
                ItemsSource="{x:Bind ViewModel.Screenshots, Mode=OneWay}"
                SelectionChanged="History_SelectionChanged"
                SelectionMode="Single">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="vm:ScreenshotTile">
                        <Grid Padding="10,7" ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="52" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border
                                Width="52"
                                Height="34"
                                Background="{ThemeResource SurfaceOverlay}"
                                CornerRadius="4">
                                <Image Source="{x:Bind Thumbnail, Mode=OneWay}" Stretch="UniformToFill" />
                            </Border>
                            <StackPanel
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Spacing="2">
                                <TextBlock
                                    FontSize="{StaticResource FontSizeBody}"
                                    Foreground="{ThemeResource TextPrimary}"
                                    Text="{x:Bind FileName}"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    FontSize="{StaticResource FontSizeCaption}"
                                    Foreground="{ThemeResource TextTertiary}"
                                    Text="{x:Bind Subtitle}"
                                    TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!--  Sidebar footer: theme toggle + settings  -->
            <Grid
                Grid.Row="4"
                Padding="14,8"
                BorderBrush="{ThemeResource StrokeSubtle}"
                BorderThickness="0,1,0,0">
                <StackPanel Orientation="Horizontal" Spacing="2">
                    <Button
                        x:Name="ThemeButton"
                        Click="Theme_Click"
                        Style="{StaticResource IconButtonStyle}"
                        ToolTipService.ToolTip="Switch theme">
                        <FontIcon x:Name="ThemeIcon" FontSize="15" Glyph="&#xE793;" />
                    </Button>
                </StackPanel>
                <Button
                    HorizontalAlignment="Right"
                    Click="Settings_Click"
                    Style="{StaticResource IconButtonStyle}"
                    ToolTipService.ToolTip="Settings">
                    <FontIcon FontSize="15" Glyph="&#xE713;" />
                </Button>
            </Grid>
        </Grid>

        <!--  ============================  DETAIL PANE  ============================  -->
        <Grid Grid.Column="1" Background="{ThemeResource SurfaceBase}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  Empty state  -->
            <StackPanel
                x:Name="EmptyState"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="12"
                Visibility="Collapsed">
                <FontIcon
                    FontSize="38"
                    Foreground="{ThemeResource TextTertiary}"
                    Glyph="&#xEB9F;" />
                <TextBlock
                    HorizontalAlignment="Center"
                    FontSize="{StaticResource FontSizeSubtitle}"
                    Foreground="{ThemeResource TextSecondary}"
                    Text="No captures yet" />
                <TextBlock
                    HorizontalAlignment="Center"
                    FontSize="{StaticResource FontSizeBody}"
                    Foreground="{ThemeResource TextTertiary}"
                    Text="Press Ctrl + Shift + S to capture a region" />
            </StackPanel>

            <!--
                Preview well. Sunken so the capture reads as inset from the chrome. The image and
                the metadata are assigned from code rather than bound through ViewModel.Selected:
                an x:Bind path that walks a null intermediate evaluates every hop, and Selected is
                null whenever the history is empty.
            -->
            <!--  Top margin clears the caption-button cluster floating over the pane's top-right.  -->
            <Border
                x:Name="PreviewWell"
                Margin="24,48,24,0"
                Background="{ThemeResource SurfaceSunken}"
                BorderBrush="{ThemeResource StrokeSubtle}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusContainer}"
                Visibility="Collapsed">
                <Image
                    x:Name="PreviewImage"
                    Margin="20"
                    Stretch="Uniform" />
            </Border>

            <!--  Metadata + actions  -->
            <Grid
                x:Name="DetailBar"
                Grid.Row="1"
                Padding="24,12"
                Visibility="Collapsed">
                <StackPanel VerticalAlignment="Center" Spacing="3">
                    <TextBlock
                        x:Name="TitleText"
                        FontSize="{StaticResource FontSizeSubtitle}"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource TextPrimary}"
                        TextTrimming="CharacterEllipsis" />
                    <TextBlock
                        x:Name="MetaText"
                        FontSize="{StaticResource FontSizeCaption}"
                        Foreground="{ThemeResource TextTertiary}" />
                </StackPanel>

                <StackPanel
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="8">
                    <Button
                        Click="Reveal_Click"
                        Style="{StaticResource ShellButtonStyle}"
                        ToolTipService.ToolTip="Show in File Explorer">
                        <FontIcon FontSize="14" Glyph="&#xE838;" />
                    </Button>
                    <Button
                        Click="Delete_Click"
                        Style="{StaticResource ShellButtonStyle}"
                        ToolTipService.ToolTip="Remove from history">
                        <FontIcon FontSize="14" Glyph="&#xE74D;" />
                    </Button>
                    <Button
                        Click="Copy_Click"
                        Style="{StaticResource ShellButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon FontSize="14" Glyph="&#xE8C8;" />
                            <TextBlock Text="Copy" />
                        </StackPanel>
                    </Button>
                    <Button
                        Click="Annotate_Click"
                        Style="{StaticResource ShellAccentButtonStyle}"
                        ToolTipService.ToolTip="Open in the editor">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon FontSize="14" Glyph="&#xE70F;" />
                            <TextBlock Text="Edit" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>

        <!--  ============================  SETTINGS  ============================  -->
        <!--
            Settings replace the detail pane in place rather than opening a dialog: every change
            applies immediately, so there is nothing to confirm or cancel. The ScrollViewer is the
            pane's own viewport — rows sit directly in it, with hairline separators doing the
            grouping instead of nested cards.
        -->
        <Grid
            x:Name="SettingsPane"
            Grid.Column="1"
            Background="{ThemeResource SurfaceBase}"
            Visibility="Collapsed">
            <Grid.Resources>
                <Style x:Key="SettingTitleStyle" TargetType="TextBlock">
                    <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
                    <Setter Property="Foreground" Value="{ThemeResource TextPrimary}" />
                </Style>
                <Style x:Key="SettingCaptionStyle" TargetType="TextBlock">
                    <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}" />
                    <Setter Property="Foreground" Value="{ThemeResource TextTertiary}" />
                    <Setter Property="TextWrapping" Value="Wrap" />
                </Style>
                <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
                    <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Setter Property="Foreground" Value="{ThemeResource TextTertiary}" />
                    <Setter Property="Margin" Value="0,20,0,2" />
                </Style>
                <Style x:Key="SettingRowStyle" TargetType="Grid">
                    <Setter Property="Padding" Value="0,9" />
                    <Setter Property="BorderBrush" Value="{ThemeResource StrokeSubtle}" />
                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                    <Setter Property="ColumnSpacing" Value="24" />
                </Style>
                <Style BasedOn="{StaticResource ShellButtonStyle}" TargetType="controls:HotkeyRecorder" />
            </Grid.Resources>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  Header. The close button's right margin is set from code to clear the native
                  caption buttons, which overlay this pane's top-right corner because content
                  extends into the titlebar.  -->
            <Grid
                Padding="28,18"
                BorderBrush="{ThemeResource StrokeSubtle}"
                BorderThickness="0,0,0,1">
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="{StaticResource FontSizeTitle}"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource TextPrimary}"
                    Text="Settings" />
                <Button
                    x:Name="SettingsCloseButton"
                    Width="36"
                    Height="36"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Click="CloseSettings_Click"
                    Style="{StaticResource IconButtonStyle}"
                    ToolTipService.ToolTip="Close settings">
                    <FontIcon FontSize="14" Glyph="&#xE711;" />
                </Button>
            </Grid>

            <!--  Centred, capped column. No overpan toggle exists (microsoft-ui-xaml #108), so
                  ViewChanged snaps rubber-band overscroll back to the edge in code.  -->
            <ScrollViewer
                x:Name="SettingsScroller"
                Grid.Row="1"
                IsScrollInertiaEnabled="False"
                ViewChanged="SettingsScroller_ViewChanged">
                <!--  Stretch + MaxWidth: rows fill the column, and the column centres itself.  -->
                <StackPanel MaxWidth="640" Margin="32,0,32,24">

                    <!--  CAPTURE  -->
                    <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="CAPTURE" />

                    <Grid Style="{StaticResource SettingRowStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center" Spacing="2">
                            <TextBlock Style="{StaticResource SettingTitleStyle}" Text="Save folder" />
                            <TextBlock
                                x:Name="FolderText"
                                Style="{StaticResource SettingCaptionStyle}"
                                Text="" />
                        </StackPanel>
                        <Button
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Click="BrowseFolder_Click"
                            Content="Change…"
                            Style="{StaticResource ShellButtonStyle}" />
                    </Grid>

                    <Grid Style="{StaticResource SettingRowStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            VerticalAlignment="Center"
                            Style="{StaticResource SettingTitleStyle}"
                            Text="Default capture mode" />
                        <ComboBox
                            x:Name="CaptureModeBox"
                            Grid.Column="1"
                            MinWidth="148"
                            VerticalAlignment="Center"
                            SelectionChanged="CaptureMode_Changed">
                            <ComboBoxItem Content="Full screen" />
                            <ComboBoxItem Content="Region" />
                            <ComboBoxItem Content="Active window" />
                            <ComboBoxItem Content="Monitor" />
                        </ComboBox>
                    </Grid>

                    <Grid Style="{StaticResource SettingRowStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center" Spacing="2">
                            <TextBlock Style="{StaticResource SettingTitleStyle}" Text="Copy to clipboard automatically" />
                            <TextBlock Style="{StaticResource SettingCaptionStyle}" Text="Every capture lands on the clipboard, ready to paste." />
                        </StackPanel>
                        <ToggleSwitch
                            x:Name="ClipboardToggle"
                            Grid.Column="1"
                            MinWidth="0"
                            VerticalAlignment="Center"
                            OffContent=""
                            OnContent=""
                            Toggled="Clipboard_Toggled" />
                    </Grid>

                    <Grid Style="{StaticResource SettingRowStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center" Spacing="2">
                            <TextBlock Style="{StaticResource SettingTitleStyle}" Text="Save screenshots automatically" />
                            <TextBlock Style="{StaticResource SettingCaptionStyle}" Text="Captures are written straight into the save folder." />
                        </StackPanel>
                        <ToggleSwitch
                            x:Name="SaveToggle"
                            Grid.Column="1"
                            MinWidth="0"
                            VerticalAlignment="Center"
                            OffContent=""
                            OnContent=""
                            Toggled="Save_Toggled" />
                    </Grid>

                    <!--  SHORTCUTS  -->
                    <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="SHORTCUTS" />
                    <TextBlock
                        Margin="0,0,0,6"
                        Style="{StaticResource SettingCaptionStyle}"
                        Text="Click a shortcut, then press the new keys. A single key such as F9 or PrtScn works too. Backspace restores the default, Esc cancels." />

                    <Grid Style="{StaticResource SettingRowStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            VerticalAlignment="Center"
                            Style="{StaticResource SettingTitleStyle}"
                            Text="Capture region" />
                        <controls:HotkeyRecorder x:Name="RegionRecorder" Grid.Column="1" />
                    </Grid>

                    <Grid Style="{StaticResource SettingRowStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            VerticalAlignment="Center"
                            Style="{StaticResource SettingTitleStyle}"
                            Text="Capture full screen" />
                        <controls:HotkeyRecorder x:Name="FullScreenRecorder" Grid.Column="1" />
                    </Grid>

                    <Grid Style="{StaticResource SettingRowStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            VerticalAlignment="Center"
                            Style="{StaticResource SettingTitleStyle}"
                            Text="Capture active window" />
                        <controls:HotkeyRecorder x:Name="ActiveWindowRecorder" Grid.Column="1" />
                    </Grid>

                    <Grid Style="{StaticResource SettingRowStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            VerticalAlignment="Center"
                            Style="{StaticResource SettingTitleStyle}"
                            Text="Open NexusShot" />
                        <controls:HotkeyRecorder x:Name="OpenWindowRecorder" Grid.Column="1" />
                    </Grid>

                    <TextBlock
                        x:Name="ShortcutWarning"
                        Margin="0,8,0,0"
                        FontSize="{StaticResource FontSizeCaption}"
                        Foreground="{ThemeResource Danger}"
                        TextWrapping="Wrap"
                        Visibility="Collapsed" />

                    <!--  PREVIEW  -->
                    <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="PREVIEW" />

                    <Grid Style="{StaticResource SettingRowStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center" Spacing="2">
                            <TextBlock Style="{StaticResource SettingTitleStyle}" Text="Auto-dismiss after" />
                            <TextBlock Style="{StaticResource SettingCaptionStyle}" Text="Seconds before a floating preview disappears. 0 keeps it open." />
                        </StackPanel>
                        <NumberBox
                            x:Name="DismissBox"
                            Grid.Column="1"
                            MinWidth="120"
                            VerticalAlignment="Center"
                            Maximum="120"
                            Minimum="0"
                            SpinButtonPlacementMode="Hidden"
                            ValueChanged="Dismiss_Changed">
                            <!--  No border in any state, and no focus underline.  -->
                            <NumberBox.Resources>
                                <Thickness x:Key="TextControlBorderThemeThickness">0</Thickness>
                                <Thickness x:Key="TextControlBorderThemeThicknessFocused">0</Thickness>
                            </NumberBox.Resources>
                        </NumberBox>
                    </Grid>

                    <!--  GENERAL  -->
                    <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="GENERAL" />

                    <Grid Style="{StaticResource SettingRowStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            VerticalAlignment="Center"
                            Style="{StaticResource SettingTitleStyle}"
                            Text="Theme" />
                        <ComboBox
                            x:Name="ThemeBox"
                            Grid.Column="1"
                            MinWidth="148"
                            VerticalAlignment="Center"
                            SelectionChanged="ThemeSetting_Changed">
                            <ComboBoxItem Content="System" />
                            <ComboBoxItem Content="Light" />
                            <ComboBoxItem Content="Dark" />
                        </ComboBox>
                    </Grid>

                    <Grid Style="{StaticResource SettingRowStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            VerticalAlignment="Center"
                            Style="{StaticResource SettingTitleStyle}"
                            Text="Start NexusShot with Windows" />
                        <ToggleSwitch
                            x:Name="StartupToggle"
                            Grid.Column="1"
                            MinWidth="0"
                            VerticalAlignment="Center"
                            OffContent=""
                            OnContent=""
                            Toggled="Startup_Toggled" />
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
